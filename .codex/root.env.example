# Safe defaults for Codex cloud and other ephemeral dev environments.
# This file is copied to the ignored repo-root .env only when .env is missing.

KLUSTER_API_KEY=codex-stub
KLUSTER_API_BASE_URL=https://example.invalid

PORT=3000
CORS_ORIGIN=http://localhost:5173
SITE_URL=http://localhost:3000

# Keep the Instagram worker off unless a task explicitly needs real API keys.
IG_WORKER_ENABLED=false
IG_DEV_BEARER=codex-dev-bearer
IG_DEV_USER_ID=codex-dev

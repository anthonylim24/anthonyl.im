# Safe defaults for Codex cloud and other ephemeral dev environments.
# This file is copied to frontend/.env.local only when that file is missing.

VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

VITE_CLERK_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Avoid stale service-worker state in short-lived cloud containers.
VITE_ENABLE_SERVICE_WORKER=false

VITE_GOOGLE_PLACES_API_KEY=
VITE_GOOGLE_MAP_TILES_API_KEY=

# Matches IG_DEV_BEARER from .codex/root.env.example for Clerk-free Korea route work.
VITE_DEV_BEARER=codex-dev-bearer

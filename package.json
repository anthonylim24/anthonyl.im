{
  "name": "anthonyl.im",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run server/app.ts",
    "dev": "pushd frontend && bun run build && popd && bun --watch server/app.ts",
    "codex:setup": "bash .codex/setup.sh",
    "codex:maintenance": "bash .codex/maintenance.sh",
    "codex:dev": "bash .codex/dev.sh",
    "codex:check": "bash .codex/check.sh",
    "codex:test": "bash .codex/cloud-setup.test.sh",
    "test": "bun test --bail",
    "test:int": "INTEGRATION=1 bun test --bail",
    "test:eval": "bun run server/src/igPlaces/eval/run.ts"
  },
  "devDependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.11",
    "groq-sdk": "^1.2.0",
    "hono": "^4.12.18",
    "openai": "^6.37.0",
    "posthog-js": "^1.373.4",
    "zod": "^4.4.3"
  }
}

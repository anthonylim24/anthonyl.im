# PostHog analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Clerk authentication
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase backend
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PWA service worker + offline cache. Defaults to on (unset == on). Set to
# "false" / "0" / "no" / "off" to disable; doing so actively unregisters any
# previously-installed worker and deletes its caches on next visit — the
# escape hatch for stale-bundle PWA traps.
VITE_ENABLE_SERVICE_WORKER=true

# Google Places API (New) key — primary photo source for the Map Mode
# bottom sheet. When set, we hit places.googleapis.com/v1/places:searchText
# with the place's name + city to fetch a real photo. When unset (or the
# place isn't found), we fall back to the Wikipedia pageimages lookup.
# Apply an HTTP-referrer restriction on the key in Google Cloud Console
# to prevent third-party reuse.
VITE_GOOGLE_PLACES_API_KEY=

# Google Map Tiles API key (separate SKU from Places). Used by the
# "Detailed 3D" debug toggle in Map Mode to stream Google's
# photorealistic 3D mesh of Seoul + Busan. 1,000 free root-tileset
# requests/month covers a personal-scale site. If unset, we fall back
# to VITE_GOOGLE_PLACES_API_KEY (you can enable both APIs on the same
# key); if neither is set, the toggle renders a "key required"
# affordance instead of mounting the 3D tiles.
VITE_GOOGLE_MAP_TILES_API_KEY=

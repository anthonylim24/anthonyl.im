# PostHog analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Clerk authentication
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase backend
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PWA service worker + offline cache. Defaults to on (unset == on). Set to
# "false" / "0" / "no" / "off" to disable; doing so actively unregisters any
# previously-installed worker and deletes its caches on next visit — the
# escape hatch for stale-bundle PWA traps.
VITE_ENABLE_SERVICE_WORKER=true
